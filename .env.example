# ─── Firebase ───────────────────────────────────────────────
# Get these from: Firebase Console → Project Settings → Your Apps
PUBLIC_FIREBASE_API_KEY=AIzaSy...
PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
PUBLIC_FIREBASE_PROJECT_ID=your-project-id
PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
PUBLIC_FIREBASE_APP_ID=1:123456789:web:abcdef

# ─── ImgBB ──────────────────────────────────────────────────
# Get this from: https://api.imgbb.com/  (free, no credit card)
PUBLIC_IMGBB_API_KEY=your_imgbb_key_here

# ─── Site ───────────────────────────────────────────────────
PUBLIC_SITE_URL=https://your-site.pages.dev
PUBLIC_SITE_NAME=দাওয়াহ
