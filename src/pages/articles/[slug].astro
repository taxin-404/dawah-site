---
// src/pages/articles/[slug].astro
export const prerender = false;

import BaseLayout from "../../layouts/BaseLayout.astro";
import { getLangFromUrl, useTranslations, langDir } from "../../i18n/ui";
import { getArticleBySlug } from "../../lib/firebase";

const { slug } = Astro.params;
const lang = getLangFromUrl(Astro.url);
const t    = useTranslations(lang);
const dir  = langDir[lang];

if (!slug) return Astro.redirect("/articles");

const article = await getArticleBySlug(slug).catch(() => null);
if (!article) return Astro.redirect("/articles");

const title   = article.title?.[lang]   || article.title?.en   || "Untitled";
const content  = article.content?.[lang]  || article.content?.en  || "";
const excerpt  = article.excerpt?.[lang]  || article.excerpt?.en  || "";

function formatDate(date: any): string {
  const d = date?.toDate ? date.toDate() : new Date(date);
  return d.toLocaleDateString(
    lang === "ar" ? "ar-SA" : lang === "bn" ? "bn-BD" : "en-GB",
    { year: "numeric", month: "long", day: "numeric" }
  );
}
---

<BaseLayout title={`${title} — Dawah`} description={excerpt} image={article.imageUrl}>
  <article class="article-single" dir={dir}>

    <!-- Hero image -->
    {article.imageUrl && (
      <div class="article-single__hero">
        <img src={article.imageUrl} alt={title} class="article-single__hero-img" />
        <div class="article-single__hero-overlay"></div>
      </div>
    )}

    <!-- Content -->
    <div class="container article-single__content">

      <!-- Tags -->
      {article.tags?.length > 0 && (
        <div class="article-single__tags">
          {article.tags.map((tag: string) => (
            <a href={`/articles?tag=${encodeURIComponent(tag)}`} class="article-single__tag">{tag}</a>
          ))}
        </div>
      )}

      <!-- Title -->
      <h1 class="article-single__title" lang={lang}>{title}</h1>

      <!-- Meta -->
      <div class="article-single__meta">
        <span>{t("article.by")} <strong>{article.author ?? "Admin"}</strong></span>
        <span class="article-single__dot">·</span>
        <time>{formatDate(article.publishedAt)}</time>
      </div>

      <!-- Bismillah -->
      <div class="article-single__bismillah">
        <span lang="ar">بِسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ</span>
      </div>

      <!-- Body -->
      <div class="article-single__body prose" lang={lang} set:html={content} />

      <!-- Back -->
      <div class="article-single__back">
        <a href={lang === "en" ? "/articles" : `/${lang}/articles`} class="btn btn-outline">
          ← {t("nav.articles")}
        </a>
      </div>

    </div>
  </article>
</BaseLayout>

<style>
  /* Hero image */
  .article-single__hero {
    position: relative;
    height: clamp(240px, 40vw, 480px);
    overflow: hidden;
  }
  .article-single__hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .article-single__hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, transparent 40%, rgba(10,31,18,0.4));
  }

  /* Content */
  .article-single__content {
    max-width: 780px;
    padding-block: 3rem 5rem;
  }

  /* Tags */
  .article-single__tags { display: flex; gap: 0.5rem; flex-wrap: wrap; margin-bottom: 1rem; }
  .article-single__tag {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--gold-700);
    background: var(--gold-50);
    padding: 2px 8px;
    border-radius: 3px;
    border: 1px solid var(--gold-100);
  }

  /* Title */
  .article-single__title {
    font-size: clamp(1.7rem, 4vw, 2.8rem);
    font-weight: 600;
    color: var(--text-700);
    line-height: 1.25;
    margin-bottom: 1rem;
  }
  :lang(ar) .article-single__title { font-family: var(--font-ar); }
  :lang(bn) .article-single__title { font-family: var(--font-bn); }
  :lang(en) .article-single__title { font-family: var(--font-en); }

  /* Meta */
  .article-single__meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.88rem;
    color: var(--text-300);
    margin-bottom: 2rem;
  }
  .article-single__dot { color: var(--cream-3); }

  /* Bismillah */
  .article-single__bismillah {
    text-align: center;
    padding-block: 1.5rem;
    margin-bottom: 2rem;
    border-block: 1px solid var(--cream-3);
  }
  .article-single__bismillah span {
    font-family: var(--font-ar);
    font-size: 1.6rem;
    color: var(--green-600);
  }

  /* Prose body */
  .prose {
    font-size: 1.05rem;
    line-height: 1.85;
    color: var(--text-700);
  }
  :lang(ar).prose { font-family: var(--font-ar); font-size: 1.15rem; }
  :lang(bn).prose { font-family: var(--font-bn); }
  :lang(en).prose { font-family: var(--font-en); font-size: 1.15rem; }

  .prose :global(p)          { margin-bottom: 1.4rem; }
  .prose :global(h2)         { font-size: 1.5rem; font-weight: 600; margin-block: 2rem 1rem; color: var(--green-700); }
  .prose :global(h3)         { font-size: 1.2rem; font-weight: 600; margin-block: 1.5rem 0.75rem; }
  .prose :global(blockquote) { border-inline-start: 3px solid var(--gold-500); padding-inline-start: 1rem; color: var(--text-500); font-style: italic; margin-block: 1.5rem; }
  .prose :global(strong)     { font-weight: 700; color: var(--text-700); }
  .prose :global(a)          { color: var(--green-600); text-decoration: underline; text-underline-offset: 3px; }

  /* Back button */
  .article-single__back { margin-top: 3rem; padding-top: 2rem; border-top: 1px solid var(--cream-3); }
</style>
