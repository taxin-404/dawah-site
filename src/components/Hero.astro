---
// src/components/Hero.astro
import { useTranslations, getLocalePath, type Lang } from "../i18n/ui";

interface Props { lang: Lang; }
const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section class="hero pattern-bg">
  <!-- Geometric overlay -->
  <div class="hero__overlay"></div>

  <div class="container hero__inner">

    <!-- Bismillah -->
    <div class="hero__bismillah-wrap" aria-label="Bismillah">
      <p class="bismillah">{t("hero.bismillah")}</p>
      <p class="hero__bismillah-translation">{t("hero.tagline")}</p>
    </div>

    <!-- Decorative divider -->
    <div class="hero__divider">
      <svg width="120" height="12" viewBox="0 0 120 12" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <line x1="0" y1="6" x2="46" y2="6" stroke="#c9a465" stroke-opacity="0.5" stroke-width="1"/>
        <path d="M54 6 L60 1 L66 6 L60 11 Z" fill="#c9a465" fill-opacity="0.8"/>
        <line x1="74" y1="6" x2="120" y2="6" stroke="#c9a465" stroke-opacity="0.5" stroke-width="1"/>
      </svg>
    </div>

    <!-- Tagline -->
    <h1 class="hero__tagline">{t("hero.subtitle")}</h1>

    <!-- CTA -->
    <a href={getLocalePath("/articles", lang)} class="btn btn-primary hero__cta">
      {t("hero.cta")}
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
        <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </a>

    <!-- Stats bar -->
    <div class="hero__stats">
      <div class="hero__stat">
        <span class="hero__stat-number" id="stat-articles">—</span>
        <span class="hero__stat-label" lang="en">Articles</span>
      </div>
      <div class="hero__stat-sep"></div>
      <div class="hero__stat">
        <span class="hero__stat-number">3</span>
        <span class="hero__stat-label" lang="en">Languages</span>
      </div>
      <div class="hero__stat-sep"></div>
      <div class="hero__stat">
        <span class="hero__stat-number">∞</span>
        <span class="hero__stat-label" lang="en">Free</span>
      </div>
    </div>

  </div>

  <!-- Bottom wave -->
  <div class="hero__wave" aria-hidden="true">
    <svg viewBox="0 0 1440 60" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M0,30 C360,60 1080,0 1440,30 L1440,60 L0,60 Z" fill="#fdfaf4"/>
    </svg>
  </div>
</section>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    padding-block: 6rem 7rem;
    text-align: center;
  }

  .hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(160deg, rgba(10,31,18,0.92) 0%, rgba(13,43,26,0.85) 100%);
    pointer-events: none;
  }

  .hero__inner {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    max-width: 760px;
  }

  /* Bismillah */
  .hero__bismillah-wrap { display: flex; flex-direction: column; gap: 0.4rem; }
  .bismillah { font-size: clamp(2rem, 5vw, 3.2rem); }
  .hero__bismillah-translation {
    font-family: var(--font-en);
    font-style: italic;
    color: rgba(229,212,160,0.7);
    font-size: clamp(0.9rem, 2vw, 1.1rem);
    letter-spacing: 0.03em;
  }

  /* Tagline */
  .hero__tagline {
    font-family: var(--font-en);
    font-size: clamp(1.3rem, 3vw, 1.9rem);
    font-weight: 400;
    color: var(--cream);
    max-width: 600px;
    line-height: 1.5;
  }
  :lang(bn) .hero__tagline { font-family: var(--font-bn); font-size: clamp(1.1rem, 2.5vw, 1.6rem); }
  :lang(ar) .hero__tagline { font-family: var(--font-ar); font-size: clamp(1.3rem, 3vw, 2rem); }

  /* CTA */
  .hero__cta { margin-top: 0.5rem; font-size: 1rem; }

  /* Stats */
  .hero__stats {
    display: flex;
    align-items: center;
    gap: 2rem;
    margin-top: 1.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(201,164,101,0.2);
  }
  .hero__stat { display: flex; flex-direction: column; align-items: center; gap: 0.2rem; }
  .hero__stat-number {
    font-family: var(--font-en);
    font-size: 1.8rem;
    font-weight: 600;
    color: var(--gold-400);
    line-height: 1;
  }
  .hero__stat-label {
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(253,250,244,0.5);
  }
  .hero__stat-sep {
    width: 1px;
    height: 36px;
    background: rgba(201,164,101,0.2);
  }

  /* Wave */
  .hero__wave {
    position: absolute;
    bottom: -1px;
    left: 0;
    right: 0;
    height: 60px;
  }
  .hero__wave svg { width: 100%; height: 100%; }

  @media (max-width: 600px) {
    .hero { padding-block: 4rem 5.5rem; }
    .hero__stats { gap: 1.25rem; }
  }
</style>

<script>
  // Animate article count from Firestore
  import { getArticles } from "../lib/firebase";
  try {
    const articles = await getArticles(100);
    const el = document.getElementById("stat-articles");
    if (el) el.textContent = String(articles.length) + "+";
  } catch (_) {
    const el = document.getElementById("stat-articles");
    if (el) el.textContent = "0";
  }
</script>
